# Breach Protocol — Ghostty config (macOS / Linux)
# Place at ~/.config/ghostty/config

font-family = JetBrainsMono Nerd Font
font-size = 11

background = 100F16
foreground = CFEA65
cursor-color = CFEA65
selection-background = 00eaff
selection-foreground = 100F16
background-opacity = 0.98

palette = 0=#0a1410
palette = 1=#C34F4D
palette = 2=#8acc4a
palette = 3=#CFEA65
palette = 4=#35BBC4
palette = 5=#ff3fb0
palette = 6=#67fffa
palette = 7=#c7d1c7
palette = 8=#4a5a4d
palette = 9=#ff5577
palette = 10=#5fe37a
palette = 11=#e0ff3a
palette = 12=#5ef4ff
palette = 13=#ff74c9
palette = 14=#8afffb
palette = 15=#ffffff

window-padding-x = 20
window-padding-y = 20
