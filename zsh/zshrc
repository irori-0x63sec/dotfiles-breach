# プラグインの読み込み
source ~/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
source ~/.zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# === Breach Protocol: zsh-autosuggestions ===
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#7a8a3a,underline"

# === Breach Protocol: syntax highlighting ===
typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[default]='fg=#CFEA65'
ZSH_HIGHLIGHT_STYLES[command]='fg=#CFEA65,bold'
ZSH_HIGHLIGHT_STYLES[builtin]='fg=#CFEA65,bold'
ZSH_HIGHLIGHT_STYLES[alias]='fg=#35BBC4,bold'
ZSH_HIGHLIGHT_STYLES[function]='fg=#35BBC4,bold'
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=#C34F4D,bold'
ZSH_HIGHLIGHT_STYLES[precommand]='fg=#8acc4a'
ZSH_HIGHLIGHT_STYLES[path]='fg=#35BBC4,underline'
ZSH_HIGHLIGHT_STYLES[globbing]='fg=#6fe6f0'
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=#8acc4a'
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=#8acc4a'
ZSH_HIGHLIGHT_STYLES[comment]='fg=#4a5260,italic'
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=#ff7a7a,bold'
ZSH_HIGHLIGHT_STYLES[redirection]='fg=#C34F4D'

# 補完メニュー
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' list-colors 'di=38;2;207;234;101' 'ln=38;2;53;187;196' 'ex=38;2;138;204;74'

source ~/powerlevel10k/powerlevel10k.zsh-theme
POWERLEVEL9K_MODE="nerdfont-complete"
POWERLEVEL9K_LEFT_PROMPT_ELEMENTS=(context dir rbenv vcs)
POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS=(status root_indicator background_jobs history time)

# === Breach Protocol: P10k segments ===
POWERLEVEL9K_CONTEXT_TEMPLATE=$''
POWERLEVEL9K_CONTEXT_DEFAULT_FOREGROUND='#100F16'
POWERLEVEL9K_CONTEXT_DEFAULT_BACKGROUND='#CFEA65'

POWERLEVEL9K_DIR_HOME_FOREGROUND='#CFEA65'
POWERLEVEL9K_DIR_HOME_BACKGROUND='#282E39'
POWERLEVEL9K_DIR_HOME_SUBFOLDER_FOREGROUND='#CFEA65'
POWERLEVEL9K_DIR_HOME_SUBFOLDER_BACKGROUND='#282E39'
POWERLEVEL9K_DIR_DEFAULT_FOREGROUND='#CFEA65'
POWERLEVEL9K_DIR_DEFAULT_BACKGROUND='#282E39'
POWERLEVEL9K_DIR_ETC_FOREGROUND='#CFEA65'
POWERLEVEL9K_DIR_ETC_BACKGROUND='#282E39'

POWERLEVEL9K_VCS_CLEAN_FOREGROUND='#8acc4a'
POWERLEVEL9K_VCS_CLEAN_BACKGROUND='#282E39'
POWERLEVEL9K_VCS_UNTRACKED_FOREGROUND='#35BBC4'
POWERLEVEL9K_VCS_UNTRACKED_BACKGROUND='#282E39'
POWERLEVEL9K_VCS_MODIFIED_FOREGROUND='#C34F4D'
POWERLEVEL9K_VCS_MODIFIED_BACKGROUND='#282E39'

POWERLEVEL9K_STATUS_OK_FOREGROUND='#8acc4a'
POWERLEVEL9K_STATUS_OK_BACKGROUND='#282E39'
POWERLEVEL9K_STATUS_ERROR_FOREGROUND='#ff7a7a'
POWERLEVEL9K_STATUS_ERROR_BACKGROUND='#282E39'

POWERLEVEL9K_HISTORY_FOREGROUND='#35BBC4'
POWERLEVEL9K_HISTORY_BACKGROUND='#282E39'
POWERLEVEL9K_TIME_FOREGROUND='#100F16'
POWERLEVEL9K_TIME_BACKGROUND='#CFEA65'
POWERLEVEL9K_TIME_FORMAT='%D{%H:%M}'

alias upgrade='sudo apt update && sudo apt upgrade -y && sudo apt autoremove -y'
export PATH="$HOME/.local/bin:$PATH"
